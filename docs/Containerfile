# Packages an already-built docs site (the docs-site branch contents) into a
# static-web-server image. The build context is the docs-site branch checkout.

# Materialize /latest as a real copy of the newest vX.Y.Z/ so static-web-server
# (which refuses symlinks by default) can serve it.
FROM alpine:3 AS prep
WORKDIR /public
COPY . .
RUN apk add --no-cache jq \
 && LATEST=$(jq -r '.versions[] | select(.latest == true) | .version' versions.json) \
 && [ -n "$LATEST" ] && [ -d "$LATEST" ] \
 && rm -rf latest \
 && cp -a "$LATEST" latest

FROM docker.io/joseluisq/static-web-server:2
COPY --from=prep /public /public
ENV SERVER_PORT=8080
ENV SERVER_ROOT=/public
ENV SERVER_LOG_LEVEL=info
EXPOSE 8080
